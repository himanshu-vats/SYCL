{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:slug([A-Za-z0-9_-]+)/admin", "destination": "/admin.html" },
    { "source": "/:slug([A-Za-z0-9_-]+)", "destination": "/index.html" }
  ]
}
