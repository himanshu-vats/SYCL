rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read access for league data
    match /leagues/{slug} {
      allow read: if true;
      allow write: if false;
    }
    // Public read access for leagues index
    match /meta/{document=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
